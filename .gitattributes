# 统一文本行尾，避免 Windows/Godot 打开后产生伪修改
* text=auto

# Godot/脚本/配置/表格统一使用 LF
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.cfg text eol=lf
*.csv text eol=lf
*.godot text eol=lf
*.md text eol=lf
*.txt text eol=lf

# 批处理保持 CRLF（Windows 习惯）
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制资源禁止行尾转换
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.glb binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.ico binary
